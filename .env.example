# TrashDetectionSystem — Environment Configuration
# Copy this file to .env and customize values.

# JWT secret (MUST change in production — generate with: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=5834ce5131d1c1f14756ef634662462ef6285ee527ec0b639d1b47b3c9bd8838

# Model weights (relative to repo root)
